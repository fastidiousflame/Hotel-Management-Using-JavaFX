<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!--
  Customers.fxml — Guest Directory with search
  Controller: ui.CustomersController
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.CustomersController"
      styleClass="card"
      VBox.vgrow="ALWAYS">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

    <Label text="👥  Guest Directory" styleClass="card-title"/>
    <Separator styleClass="gold-sep"/>

    <TextField fx:id="tfSearch"
               promptText="🔍  Search by name or contact..."
               styleClass="form-field"
               onKeyReleased="#onSearch">
        <VBox.margin><Insets top="12" bottom="12"/></VBox.margin>
    </TextField>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color:#FFFFFF;">
        <columns>
            <TableColumn fx:id="colCustId"      text="Customer ID"  prefWidth="130"/>
            <TableColumn fx:id="colCustName"    text="Name"         prefWidth="170"/>
            <TableColumn fx:id="colCustContact" text="Contact"      prefWidth="130"/>
            <TableColumn fx:id="colCustEmail"   text="Email"        prefWidth="200"/>
            <TableColumn fx:id="colCustId2"     text="ID Proof"     prefWidth="160"/>
        </columns>
    </TableView>

</VBox>
