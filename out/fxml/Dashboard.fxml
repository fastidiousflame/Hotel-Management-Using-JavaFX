<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Priority?>

<!--
  Dashboard.fxml — Grand Aurora Hotel Management System
  Designed for Scene Builder. Controller: ui.DashboardController
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.DashboardController"
      style="-fx-background-color:#F4F1EC;"
      spacing="0">

    <!-- ── Stat Cards Row ── -->
    <HBox fx:id="statsRow" spacing="16" style="-fx-background-color:#F4F1EC;">
        <padding><Insets top="24" right="24" bottom="8" left="24"/></padding>

        <!-- Total Rooms Card -->
        <VBox styleClass="stat-card" style="-fx-border-color:#1565C0;"
              HBox.hgrow="ALWAYS">
            <Label text="🏨  Total Rooms" styleClass="stat-label"/>
            <Label fx:id="statTotal" text="0" styleClass="stat-value"
                   style="-fx-text-fill:#1565C0;"/>
            <Separator style="-fx-background-color:#1565C0; -fx-pref-height:3;"/>
        </VBox>

        <!-- Available Card -->
        <VBox styleClass="stat-card" style="-fx-border-color:#1A7A4A;"
              HBox.hgrow="ALWAYS">
            <Label text="✅  Available" styleClass="stat-label"/>
            <Label fx:id="statAvail" text="0" styleClass="stat-value"
                   style="-fx-text-fill:#1A7A4A;"/>
            <Separator style="-fx-background-color:#1A7A4A; -fx-pref-height:3;"/>
        </VBox>

        <!-- Occupied Card -->
        <VBox styleClass="stat-card" style="-fx-border-color:#C0392B;"
              HBox.hgrow="ALWAYS">
            <Label text="🔴  Occupied" styleClass="stat-label"/>
            <Label fx:id="statOccupied" text="0" styleClass="stat-value"
                   style="-fx-text-fill:#C0392B;"/>
            <Separator style="-fx-background-color:#C0392B; -fx-pref-height:3;"/>
        </VBox>

        <!-- Revenue Card -->
        <VBox styleClass="stat-card" style="-fx-border-color:#B8860B;"
              HBox.hgrow="ALWAYS">
            <Label text="💰  Revenue Earned" styleClass="stat-label"/>
            <Label fx:id="statRevenue" text="₹0" styleClass="stat-value"
                   style="-fx-text-fill:#B8860B;"/>
            <Separator style="-fx-background-color:#B8860B; -fx-pref-height:3;"/>
        </VBox>

        <!-- Guests Card -->
        <VBox styleClass="stat-card" style="-fx-border-color:#9B59B6;"
              HBox.hgrow="ALWAYS">
            <Label text="👥  Total Guests" styleClass="stat-label"/>
            <Label fx:id="statGuests" text="0" styleClass="stat-value"
                   style="-fx-text-fill:#9B59B6;"/>
            <Separator style="-fx-background-color:#9B59B6; -fx-pref-height:3;"/>
        </VBox>
    </HBox>

    <!-- ── Quick Action Buttons ── -->
    <HBox spacing="12">
        <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
        <Button fx:id="btnNewBooking" text="📋  New Booking"
                onAction="#onNewBooking" styleClass="gold-btn"/>
        <Button fx:id="btnAddRoom"    text="🚪  Add Room"
                onAction="#onAddRoom"   styleClass="gold-btn"/>
        <Button fx:id="btnExportLog"  text="📄  Export Log"
                onAction="#onExportLog" styleClass="gold-btn"/>
    </HBox>

    <!-- ── Recent Activity ── -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="24" bottom="16" left="24"/></padding>
        <Label text="Recent Activity" styleClass="section-label"/>
        <Separator styleClass="gold-sep"/>
        <ListView fx:id="recentList" VBox.vgrow="ALWAYS"
                  prefHeight="300"
                  style="-fx-background-color:#FFFFFF; -fx-border-color:#DDD8CF;"/>
    </VBox>

</VBox>
