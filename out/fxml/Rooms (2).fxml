<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<SplitPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ui.RoomsController"
           dividerPositions="0.38"
           style="-fx-background-color:#F5F0F8;">

    <!-- LEFT: Add Room Form -->
    <VBox styleClass="card" minWidth="280">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <Label text="Add New Room" styleClass="card-title"/>
        <Separator styleClass="gold-sep"><VBox.margin><Insets top="6" bottom="12"/></Separator>

        <GridPane hgap="16" vgap="14">
            <columnConstraints>
                <ColumnConstraints minWidth="110" prefWidth="110"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Room Number" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="tfRoomNo" promptText="e.g. 405" styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS"/>

            <Label text="Room Type" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="cbType" maxWidth="1.7976931348623157E308" styleClass="form-combo"
                      GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS"/>

            <Label text="Price / Day" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="tfPrice" promptText="e.g. 3500" styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.hgrow="ALWAYS"/>

            <Label text="Floor" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="tfFloor" promptText="e.g. 4th Floor" styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.hgrow="ALWAYS"/>

            <Label text="Capacity" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="tfCapacity" promptText="e.g. 2" styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.hgrow="ALWAYS"/>
        </GridPane>

        <HBox spacing="10"><padding><Insets top="14"/></padding>
            <Button text="Add Room" onAction="#onAddRoom"  styleClass="gold-btn"/>
            <Button text="Clear"    onAction="#onClearForm" styleClass="ghost-btn"/>
        </HBox>

        <Label fx:id="msgRoom" styleClass="msg-label" wrapText="true">
            <VBox.margin><Insets top="8"/></VBox.margin>
        </Label>
    </VBox>

    <!-- RIGHT: Room List Table -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <Label text="Room List" styleClass="card-title"/>
        <Separator styleClass="gold-sep"><VBox.margin><Insets top="6" bottom="8"/></Separator>

        <!-- Filter + Refresh buttons row -->
        <HBox spacing="10"><padding><Insets top="4" bottom="10"/></padding>
            <Button text="All Rooms"       onAction="#onShowAll"       styleClass="gold-btn"/>
            <Button text="Available Only"  onAction="#onShowAvailable" styleClass="ghost-btn"/>
            <Button text="Refresh Status"  onAction="#onRefresh"
                    style="-fx-background-color:#7B3F8C; -fx-text-fill:#FFFFFF;
                           -fx-font-weight:bold; -fx-font-size:13px;
                           -fx-padding:10 18; -fx-background-radius:8; -fx-cursor:hand;"/>
        </HBox>

        <TableView fx:id="roomTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colRoomNo"  text="Room #"    prefWidth="80"/>
                <TableColumn fx:id="colType"    text="Type"      prefWidth="100"/>
                <TableColumn fx:id="colFloor"   text="Floor"     prefWidth="110"/>
                <TableColumn fx:id="colCapacity" text="Capacity" prefWidth="90"/>
                <TableColumn fx:id="colPrice"   text="Price/Day" prefWidth="110"/>
                <TableColumn fx:id="colStatus"  text="Status"    prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

</SplitPane>
