<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>

<!--
  Rooms.fxml — Add Rooms + Room List Table
  Controller: ui.RoomsController
-->
<SplitPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ui.RoomsController"
           dividerPositions="0.38"
           style="-fx-background-color:#F4F1EC;">

    <!-- ══ LEFT — Add Room Form ══ -->
    <VBox styleClass="card" minWidth="280">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <Label text="➕  Add New Room" styleClass="card-title"/>
        <Separator styleClass="gold-sep"/>

        <GridPane fx:id="addRoomGrid" hgap="16" vgap="14">
            <padding><Insets top="16" right="0" bottom="0" left="0"/></padding>
            <columnConstraints>
                <ColumnConstraints minWidth="110" prefWidth="110"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Row 0: Room Number -->
            <Label text="Room Number" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="tfRoomNo" promptText="e.g. 405"
                       styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"
                       GridPane.hgrow="ALWAYS"/>

            <!-- Row 1: Room Type -->
            <Label text="Room Type" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="cbType" maxWidth="1.7976931348623157E308"
                      styleClass="form-combo"
                      GridPane.columnIndex="1" GridPane.rowIndex="1"
                      GridPane.hgrow="ALWAYS"/>

            <!-- Row 2: Price -->
            <Label text="Price / Day" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="tfPrice" promptText="e.g. 3500"
                       styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"
                       GridPane.hgrow="ALWAYS"/>

            <!-- Row 3: Floor -->
            <Label text="Floor" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="tfFloor" promptText="e.g. 4th Floor"
                       styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"
                       GridPane.hgrow="ALWAYS"/>

            <!-- Row 4: Capacity -->
            <Label text="Capacity" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="tfCapacity" promptText="e.g. 2"
                       styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="4"
                       GridPane.hgrow="ALWAYS"/>
        </GridPane>

        <HBox spacing="10">
            <padding><Insets top="12"/></padding>
            <Button fx:id="btnAdd"   text="➕  Add Room" onAction="#onAddRoom"  styleClass="gold-btn"/>
            <Button fx:id="btnClear" text="✖  Clear"    onAction="#onClearForm" styleClass="ghost-btn"/>
        </HBox>

        <Label fx:id="msgRoom" styleClass="msg-label" wrapText="true"/>
    </VBox>

    <!-- ══ RIGHT — Room Table ══ -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <Label text="🗂  Room List" styleClass="card-title"/>
        <Separator styleClass="gold-sep"/>

        <HBox spacing="10">
            <padding><Insets top="8" bottom="8"/></padding>
            <Button fx:id="btnAll"   text="All Rooms"      onAction="#onShowAll"       styleClass="gold-btn"/>
            <Button fx:id="btnAvail" text="Available Only" onAction="#onShowAvailable"  styleClass="ghost-btn"/>
        </HBox>

        <TableView fx:id="roomTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color:#FFFFFF;">
            <columns>
                <TableColumn fx:id="colRoomNo"   text="Room #"    prefWidth="80"/>
                <TableColumn fx:id="colType"      text="Type"      prefWidth="100"/>
                <TableColumn fx:id="colFloor"     text="Floor"     prefWidth="110"/>
                <TableColumn fx:id="colCapacity"  text="Capacity"  prefWidth="90"/>
                <TableColumn fx:id="colPrice"     text="Price/Day" prefWidth="110"/>
                <TableColumn fx:id="colStatus"    text="Status"    prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

</SplitPane>
