<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
  Checkout.fxml — Process Checkout + Active Bookings Table
  Controller: ui.CheckoutController
-->
<SplitPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="ui.CheckoutController"
           dividerPositions="0.35"
           style="-fx-background-color:#F5F0F8;">

    <!-- ══ LEFT — Checkout Panel ══ -->
    <VBox styleClass="card" minWidth="260">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <Label text="🔑  Process Checkout" styleClass="card-title"/>
        <Separator styleClass="gold-sep"/>

        <GridPane hgap="12" vgap="12">
            <padding><Insets top="14"/></padding>
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Booking ID" styleClass="form-label"
                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="tfBookingId"
                       promptText="Enter Booking ID (e.g. BKG-5001)"
                       styleClass="form-field"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"
                       GridPane.hgrow="ALWAYS"/>
        </GridPane>

        <Button fx:id="btnCheckout"
                text="🔑  CHECKOUT NOW"
                onAction="#onCheckout"
                style="-fx-background-color:#C0392B; -fx-text-fill:white;
                       -fx-font-size:14; -fx-font-weight:bold;
                       -fx-padding:10 24; -fx-background-radius:8;
                       -fx-cursor:hand;
                       -fx-effect: dropshadow(gaussian, rgba(192,57,43,0.3),8,0,0,2);">
            <VBox.margin><Insets top="14"/></VBox.margin>
        </Button>

        <Label fx:id="msgCheckout" styleClass="msg-label" wrapText="true">
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Label>

        <!-- Receipt Panel (shown after successful checkout) -->
        <VBox fx:id="receiptBox" spacing="6" managed="false" visible="false"
              style="-fx-background-color:#FDF5FF; -fx-border-color:#C0788C;
                     -fx-border-radius:8; -fx-background-radius:8; -fx-padding:12;">
            <VBox.margin><Insets top="14"/></VBox.margin>
            <Label text="🧾  RECEIPT" style="-fx-font-family:'Georgia';
                         -fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#C8809C;"/>
            <Separator/>
            <Label fx:id="receiptContent"
                   style="-fx-font-family:'Courier New'; -fx-font-size:12;
                          -fx-text-fill:#1A1A2E;" wrapText="true"/>
        </VBox>
    </VBox>

    <!-- ══ RIGHT — Active Bookings Table ══ -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <Label text="🟡  Currently Active Bookings" styleClass="card-title"/>
        <Separator styleClass="gold-sep"/>

        <Label text="Click a row to auto-fill the Booking ID →"
               style="-fx-font-size:11; -fx-text-fill:#6B6878; -fx-font-style:italic;">
            <VBox.margin><Insets top="6" bottom="6"/></VBox.margin>
        </Label>

        <TableView fx:id="activeTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color:#FFFFFF;">
            <columns>
                <TableColumn fx:id="colActBkId"    text="Booking ID"  prefWidth="130"/>
                <TableColumn fx:id="colActGuest"   text="Guest"       prefWidth="160"/>
                <TableColumn fx:id="colActRoom"    text="Room #"      prefWidth="80"/>
                <TableColumn fx:id="colActCheckIn" text="Check-In"    prefWidth="120"/>
                <TableColumn fx:id="colActCheckOut" text="Check-Out"  prefWidth="120"/>
                <TableColumn fx:id="colActBill"    text="Bill (₹)"    prefWidth="110"/>
            </columns>
        </TableView>
    </VBox>

</SplitPane>
